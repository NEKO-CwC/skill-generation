{
  "id": "skill-evolution",
  "name": "Skill Evolution",
  "description": "Evolves OpenClaw skills from real usage feedback via session overlays, deterministic or LLM review, background review service, and safe merge with rollback protection.",
  "version": "0.2.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true
      },
      "merge": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "requireHumanMerge": {
            "type": "boolean",
            "default": true
          },
          "maxRollbackVersions": {
            "type": "integer",
            "minimum": 1,
            "default": 5
          }
        }
      },
      "sessionOverlay": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "storageDir": {
            "type": "string",
            "default": ".skill-overlays"
          },
          "injectMode": {
            "type": "string",
            "enum": [
              "system-context",
              "tool-description"
            ],
            "default": "system-context"
          },
          "clearOnSessionEnd": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "triggers": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "onToolError": {
            "type": "boolean",
            "default": true
          },
          "onUserCorrection": {
            "type": "boolean",
            "default": true
          },
          "onSessionEndReview": {
            "type": "boolean",
            "default": true
          },
          "onPositiveFeedback": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "llm": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "inheritPrimaryConfig": {
            "type": "boolean",
            "default": true
          },
          "modelOverride": {
            "type": ["string", "null"],
            "default": null
          },
          "thinkingOverride": {
            "type": ["boolean", "null"],
            "default": null
          },
          "mode": {
            "type": "string",
            "enum": ["inherit-or-fallback", "explicit", "disabled"],
            "default": "disabled"
          },
          "provider": {
            "type": "string",
            "enum": ["anthropic", "openai-compatible", "custom"],
            "default": "anthropic"
          },
          "baseUrlOverride": {
            "type": ["string", "null"],
            "default": null
          },
          "authProfileRef": {
            "type": ["string", "null"],
            "default": null
          },
          "keyRef": {
            "oneOf": [
              { "type": "null" },
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "source": {
                    "type": "string",
                    "enum": ["env", "file", "exec"]
                  },
                  "id": {
                    "type": "string"
                  },
                  "args": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                },
                "required": ["source", "id"]
              }
            ],
            "default": null
          },
          "allowExecSecretRef": {
            "type": "boolean",
            "default": false
          },
          "allowGatewayFallback": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "review": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "engine": {
            "type": "string",
            "enum": ["deterministic", "llm"],
            "default": "deterministic"
          },
          "minEvidenceCount": {
            "type": "integer",
            "minimum": 0,
            "default": 2
          },
          "allowAutoMergeOnLowRiskOnly": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "queue": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "pollIntervalMs": {
            "type": "integer",
            "minimum": 1000,
            "default": 30000
          },
          "leaseMs": {
            "type": "integer",
            "minimum": 10000,
            "default": 300000
          },
          "maxAttempts": {
            "type": "integer",
            "minimum": 1,
            "default": 3
          }
        }
      }
    }
  }
}
